{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Product price in INR" },
        "category": { "type": "string", "description": "Product category" },
        "stock": { "type": "integer", "description": "Available stock" },
        "emoji": { "type": "string", "description": "Emoji representation" }
      },
      "required": ["name", "price", "category", "emoji"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in a user's cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to Product ID" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "quantity": { "type": "integer", "description": "Quantity in cart" },
        "emoji": { "type": "string", "description": "Emoji representation" }
      },
      "required": ["productId", "name", "price", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the order" },
        "items": {
          "type": "array",
          "items": { "$ref": "CartItem" }
        },
        "totalPrice": { "type": "number", "description": "Total order price" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalPrice", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["displayName", "email"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Public catalog of products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/cart": {
      "schema": "CartItem",
      "description": "User's active shopping cart"
    },
    "/orders": {
      "schema": "Order",
      "description": "Global orders collection (filtered by userId in rules)"
    }
  }
}
